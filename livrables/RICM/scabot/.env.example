# ============================================================
# SCABOT — Configuration
# Copier ce fichier en .env et renseigner les valeurs
# ============================================================

# --- Google Cloud ---
GOOGLE_APPLICATION_CREDENTIALS=credentials/service_account.json
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# --- Google Drive ---
DRIVE_FOLDER_DEVIS=1xXXXXXXXXXXXXXXXXXXXXXXXX
DRIVE_FOLDER_FACTURES=1xXXXXXXXXXXXXXXXXXXXXXXXX
DRIVE_FOLDER_SORTIE=1xXXXXXXXXXXXXXXXXXXXXXXXX

# --- Gmail ---
GMAIL_SENDER=votre.email@gmail.com
EMAIL_DESTINATAIRE_DEFAUT=clement.hanser@audencia.com

# --- Mode de fonctionnement ---
# auto : envoi automatique si tous les contrôles passent
# revue : prépare en brouillon et attend validation manuelle
MODE=revue

# --- Webhook (Cloud Run) ---
# URL publique de ce service Cloud Run (pour enregistrer les notifications Drive)
WEBHOOK_URL=https://scabot-xxxx-ew.a.run.app/webhook

# --- OCR ---
# vision_api : Google Cloud Vision (recommandé)
# tesseract  : OCR local (fallback)
OCR_ENGINE=vision_api

# --- Seuils de confiance ---
CPV_SCORE_MIN=0.45          # En dessous : suspension + alerte
MONTANT_ECART_MAX=0.01      # Tolérance écart montant fiche/document (1%)
